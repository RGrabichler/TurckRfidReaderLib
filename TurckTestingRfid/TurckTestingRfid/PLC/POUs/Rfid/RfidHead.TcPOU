      </Implementation>
    </Method>
    <Method Name="ServiceMode" Id="{c8436f55-4a15-04a3-0a72-f480ef0481d3}">
      <Declaration><![CDATA[(*~
    <docu>
        <summary>
            Custom service (manual, maintenance) logic.
            This method must be implemented in derived class.
        </summary>
    </docu>
~*)
METHOD PROTECTED ServiceMode
