  <POU Name="RfidHead" Id="{493afb4f-2fea-099f-1b9d-030e31435103}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK RfidHead EXTENDS TcoCore.TcoComponent
VAR_OUTPUT
    sUId : T_MaxString;
END_VAR
VAR
    xExecute          : BOOL;
    xAbort            : BOOL;
    udiTimeOut        : UDINT;
    eCommand          : RFID_FB_U.COMMAND;
    rControllMapping  : RFID_FB_U.CompactOutput_t;
    udiStartAdress    : UDINT;
    uiDataLenght      : UINT;
    pWriteDataMapping : ARRAY[0..127] OF BYTE;
    pDataTx           : ARRAY[0..127] OF BYTE;

    xDone               : BOOL;
    xBusy               : BOOL;
    xError              : BOOL;
    xAborted            : BOOL;
    eErrorID            : RFID_FB_U.ERROR;
    xTP                 : BOOL;
    xRWHeadNotCOnnected : BOOL;
    udiDataRxLength      : UINT;
    rStatusMapping      : RFID_FB_U.CompactInput_t;
    pReadDataMapping    : ARRAY[0..127] OF BYTE;
    pDataRx             : ARRAY[0..127] OF BYTE;
END_VAR
VAR
    _itfRfidHeadWrapper : IRfidHeadWrapper;

    _readUidTask : ReadUidTask(THIS^, _itfRfidHeadWrapper);

END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[//_readUidTask(turckRfid := turckRfid, ActionDesc := '<#ReadUid#>', sUid => sUId);
//turckRfid.Execute
//(
//    xExecute            :=
//    , rStatusMapping    := stCompactModeInputMap
//    , rControlMapping   := stCompactModeOutputMap
//    , pReadDataMapping  := abyRxDataMapCompactMode
//    , pWriteDataMapping := abyTxDataMapCompactMode
//    , pDataTx           := myWriteData
//    , pDataRx           := myReadData
//);

_itfRfidHeadWrapper.Execute
(
    xExecute              := xExecute
    , xAbort              := xAbort
    , udiTimeOut          := udiTimeOut
    , eCommand            := eCommand
    , rControllMapping    := rControllMapping
    , udiStartAdress      := udiStartAdress
    , udiDataLenght        := uiDataLenght
    , pWriteDataMapping   := pWriteDataMapping
    , pDataTx             := pDataTx
    , xDone               => xDone
    , xBusy               => xBusy
    , xError              => xError
    , xAborted            => xAborted
    , eErrorID            => eErrorID
    , xTP                 => xTP
    , xRWHeadNotCOnnected => xRWHeadNotCOnnected
    , uiDataRxLength      => udiDataRxLength
    , rStatusMapping      => rStatusMapping
    , pReadDataMapping    => pReadDataMapping
    , pDataRx             => pDataRx
);

IF _itfRfidHeadWrapper <> 0 THEN
    _readUidTask();
END_IF

